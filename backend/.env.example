SYNC_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/labinsight
SECRET_KEY=your-super-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080
